{
  "compilerOptions": {
    "target": "es5",
    "lib": ["es5", "dom"],
    "module": "es2015",
    "outDir": "./build/",
    "allowImportingTsExtensions": true,
    "moduleResolution": "bundler",
    "emitDeclarationOnly": true,
    "declaration": true,
    "noUnusedLocals": false, 
    "noUnusedParameters": false,
    "rootDir": "./src/",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true
  },
  "include": [
      "src/**/*.ts"
  ],
  "exclude": ["node_modules"]
}
