{
  "devDependencies": {
    "esbuild": "^0.24.0",
    "nodemon": "^3.0.0",
    "typescript": "^5.7.2"
  },
  "scripts": {
    "watch:ts": "npx tsc --watch",
    "watch:bundle": "nodemon -e js -x \"node build.js\"",
    "dev": "npm run watch:ts\" \"npm run watch:bundle\"",
    "build:ts": "npx tsc --target es5",
    "build:bundle": "node build.js",
    "build": "npm run build:ts "
  }
}
